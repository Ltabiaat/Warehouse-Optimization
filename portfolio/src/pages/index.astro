---
const title = 'Lancelot Tabiaat — Data Scientist & AI Consultant';
const description = 'Data Scientist & AI Consultant building practical optimization systems with machine learning, reinforcement learning, analytics, and scalable data pipelines.';

const experience = [
  {
    role: 'Data Science Consultant',
    company: 'Guide Robotics',
    meta: 'Contract · Japan · Feb 2026 — Present',
    bullets: [
      'Work directly with the CTO to identify operational pain points and translate them into technical roadmaps.',
      'Develop reinforcement learning approaches to improve warehouse throughput and optimization outcomes.',
      'Build end-to-end data pipelines and analytics dashboards to support monitoring and decision-making.'
    ]
  },
  {
    role: 'Intern',
    company: 'NEC',
    meta: 'Japan · Sep 2024 — Dec 2024',
    bullets: [
      'Collaborated with fellow interns to develop strategic solutions for NEC clients.',
      'Led presentations to NEC management on innovative uses of existing infrastructure.',
      'Used proprietary technologies to strengthen client-facing service offerings.'
    ]
  },
  {
    role: 'Intern',
    company: 'InfoTech Solution',
    meta: 'Oman · Apr 2022 — Aug 2022',
    bullets: [
      'Built websites for client companies with modern design and functional requirements.',
      'Automated internal and client workflows to improve efficiency.',
      'Connected web-based systems with third-party APIs and external data providers.'
    ]
  }
];

const projects = [
  {
    name: 'Warehouse Optimization',
    description:
      'A reinforcement learning platform built with Gymnasium to simulate warehouse layouts and routes, optimize throughput, and surface results through business-facing analytics dashboards.'
  },
  {
    name: 'Urban-Score',
    description:
      'A product concept for real estate agents that uses image-based filtering and market evaluation to support faster, more informed property decisions.'
  }
];

const leadership = [
  {
    role: 'Founder',
    org: 'Tokyo Student Network',
    meta: 'Sep 2025 — Present',
    bullets: [
      'Founded and operate a student-led non-profit connecting students across universities in Tokyo to share opportunities and resources.',
      'Built a 50+ member community with a 4-person core team.',
      'Organized 5 free events with 120+ total attendees by securing speakers, venues, and partnerships through direct outreach.'
    ]
  },
  {
    role: 'Administration Leader',
    org: 'TIU Impact Next',
    meta: 'Apr 2025 — Sep 2025',
    bullets: [
      'Led a team of 14, assigning responsibilities based on strengths to keep operations smooth for a 70+ attendee flagship event.',
      'Developed event themes and proposals in close collaboration with club leadership.',
      'Acted as a liaison across departments to maintain alignment, communication, and execution quality.'
    ]
  }
];

const education = [
  {
    school: 'Tokyo International University (TIU)',
    detail: 'Bachelor of Science in Digital Business & Innovations · Tokyo, Japan · 2022 — 2026',
    extra: 'GPA: 3.7/4.0'
  },
  {
    school: 'Radboud University',
    detail: 'Exchange Semester in Computing Science · Nijmegen, Netherlands · Spring 2024',
    extra: 'Coursework included AI, OOP, and Requirements Engineering & Design.'
  },
  {
    school: 'Le Wagon Tokyo',
    detail: 'Intensive Bootcamp in Data Science & AI · Tokyo, Japan · Jan — Mar 2026',
    extra: 'Coursework included Data Analysis, Decision Science, Machine Learning, Deep Learning, and ML Ops.'
  }
];

const skillGroups = [
  {
    title: 'Languages & Tools',
    items: ['Python', 'SQL', 'R', 'Java', 'Pandas', 'Matplotlib', 'TensorFlow', 'Scikit-Learn', 'NLTK']
  },
  {
    title: 'Data & AI',
    items: ['Machine Learning', 'Reinforcement Learning', 'Deep Learning', 'Data Preprocessing', 'EDA', 'ML Ops', 'Analytics Pipelines']
  },
  {
    title: 'Professional Strengths',
    items: ['Stakeholder Communication', 'Presentation Skills', 'Conflict Resolution', 'Adaptability', 'Leadership']
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0f172a" />
    <style>
      :root {
        --bg: #f8fafc;
        --surface: rgba(255, 255, 255, 0.82);
        --surface-strong: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --line: rgba(15, 23, 42, 0.1);
        --accent: #1d4ed8;
        --accent-soft: rgba(29, 78, 216, 0.1);
        --shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        --radius: 24px;
        --max: 1120px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(59, 130, 246, 0.14), transparent 32%),
          radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 24%),
          var(--bg);
        line-height: 1.65;
      }

      a { color: inherit; text-decoration: none; }
      .container { width: min(calc(100% - 2rem), var(--max)); margin: 0 auto; }

      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(14px);
        background: rgba(248, 250, 252, 0.75);
        border-bottom: 1px solid rgba(15, 23, 42, 0.06);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0;
      }

      .brand {
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      main { padding: 2rem 0 5rem; }

      .hero {
        padding: 5rem 0 3rem;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 2rem;
        align-items: stretch;
      }

      .hero-card,
      .panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .hero-card {
        padding: 2.5rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-weight: 600;
        font-size: 0.9rem;
      }

      h1, h2, h3 {
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin: 0;
      }

      h1 {
        font-size: clamp(2.4rem, 5vw, 4.6rem);
        margin-top: 1rem;
      }

      .lead {
        margin-top: 1.25rem;
        font-size: 1.05rem;
        color: var(--muted);
        max-width: 62ch;
      }

      .hero-actions {
        margin-top: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.9rem 1.2rem;
        border-radius: 999px;
        font-weight: 600;
        border: 1px solid transparent;
        transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
      }

      .button:hover { transform: translateY(-1px); }
      .button.primary { background: var(--text); color: white; }
      .button.secondary { background: white; border-color: var(--line); color: var(--text); }

      .hero-side {
        padding: 1.75rem;
        display: grid;
        gap: 1rem;
      }

      .stat {
        padding: 1rem 1.1rem;
        border-radius: 18px;
        background: var(--surface-strong);
        border: 1px solid var(--line);
      }

      .stat strong {
        display: block;
        font-size: 1.5rem;
        letter-spacing: -0.03em;
      }

      .stat span {
        color: var(--muted);
        font-size: 0.95rem;
      }

      section {
        padding: 1.25rem 0;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .section-header p {
        margin: 0;
        color: var(--muted);
        max-width: 60ch;
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .two-col { grid-template-columns: 1.05fr 1fr; }
      .cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }

      .panel {
        padding: 1.5rem;
      }

      .panel h3 {
        font-size: 1.25rem;
        margin-bottom: 0.35rem;
      }

      .meta {
        color: var(--accent);
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 0.85rem;
      }

      .muted { color: var(--muted); }
      ul.clean {
        margin: 0;
        padding-left: 1.1rem;
      }
      ul.clean li + li { margin-top: 0.55rem; }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 1rem;
      }

      .chip {
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        background: white;
        border: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.92rem;
      }

      .contact-box {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 1rem;
      }

      footer {
        padding: 1rem 0 4rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      @media (max-width: 900px) {
        .hero,
        .two-col,
        .cards {
          grid-template-columns: 1fr;
        }

        .hero { padding-top: 3rem; }
        .hero-card, .hero-side, .panel { padding: 1.25rem; }
        .nav { align-items: start; flex-direction: column; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <a class="brand" href="#top">Lancelot Tabiaat</a>
        <nav class="nav-links">
          <a href="#about">About</a>
          <a href="#experience">Experience</a>
          <a href="#projects">Projects</a>
          <a href="#leadership">Leadership</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main id="top">
      <div class="container">
        <section class="hero">
          <div class="hero-card">
            <div class="eyebrow">Tokyo, Japan · Data Science · Applied AI</div>
            <h1>Data Scientist &amp; AI Consultant building practical optimization systems.</h1>
            <p class="lead">
              I design and build machine learning systems that connect technical depth with real business outcomes — from
              reinforcement learning and simulation to analytics pipelines, dashboards, and stakeholder-facing delivery.
            </p>
            <div class="hero-actions">
              <a class="button primary" href="#projects">View Projects</a>
              <a class="button secondary" href="#contact">Connect</a>
            </div>
          </div>

          <aside class="hero-card hero-side">
            <div class="stat">
              <strong>RL + Optimization</strong>
              <span>Building warehouse optimization workflows with simulation and reinforcement learning.</span>
            </div>
            <div class="stat">
              <strong>Consulting + Delivery</strong>
              <span>Experienced translating business pain points into technical systems and analytics.</span>
            </div>
            <div class="stat">
              <strong>Founder Mindset</strong>
              <span>Operator and community builder through Tokyo Student Network.</span>
            </div>
          </aside>
        </section>

        <section id="about">
          <div class="section-header">
            <div>
              <h2>About</h2>
            </div>
            <p>
              I work at the intersection of data science, applied AI, and business problem-solving. My focus is on
              building systems that are technically solid, operationally useful, and understandable to the people making decisions.
            </p>
          </div>
          <div class="grid two-col">
            <div class="panel">
              <h3>What I do</h3>
              <p class="muted">
                I build end-to-end machine learning and analytics solutions, with particular interest in optimization,
                reinforcement learning, and scalable data workflows. I enjoy turning messy real-world problems into
                structured systems that teams can use.
              </p>
            </div>
            <div class="panel">
              <h3>What I bring</h3>
              <p class="muted">
                Alongside technical execution, I bring consulting awareness, presentation skills, and founder-level ownership.
                I’m comfortable working directly with stakeholders, understanding what matters, and shipping toward outcomes.
              </p>
            </div>
          </div>
        </section>

        <section id="experience">
          <div class="section-header">
            <div><h2>Experience</h2></div>
            <p>Recent work across consulting, internships, automation, and client-facing technical delivery.</p>
          </div>
          <div class="grid">
            {experience.map((item) => (
              <article class="panel">
                <h3>{item.role} · {item.company}</h3>
                <div class="meta">{item.meta}</div>
                <ul class="clean muted">
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section id="projects">
          <div class="section-header">
            <div><h2>Projects</h2></div>
            <p>Selected projects focused on machine learning, optimization, and product-oriented thinking.</p>
          </div>
          <div class="grid cards">
            {projects.map((project) => (
              <article class="panel">
                <h3>{project.name}</h3>
                <p class="muted">{project.description}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="leadership">
          <div class="section-header">
            <div><h2>Leadership</h2></div>
            <p>Community-building and team leadership alongside technical work.</p>
          </div>
          <div class="grid cards">
            {leadership.map((item) => (
              <article class="panel">
                <h3>{item.role} · {item.org}</h3>
                <div class="meta">{item.meta}</div>
                <ul class="clean muted">
                  {item.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section>
          <div class="grid two-col">
            <div class="panel">
              <h2>Education</h2>
              <div class="grid" style="margin-top: 1rem;">
                {education.map((item) => (
                  <div>
                    <h3>{item.school}</h3>
                    <p class="muted" style="margin: 0.3rem 0 0;">{item.detail}</p>
                    <p class="muted" style="margin: 0.4rem 0 0;">{item.extra}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="panel">
              <h2>Skills</h2>
              <div class="grid" style="margin-top: 1rem; gap: 1.2rem;">
                {skillGroups.map((group) => (
                  <div>
                    <h3>{group.title}</h3>
                    <div class="chips">
                      {group.items.map((item) => <span class="chip">{item}</span>)}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="contact">
          <div class="panel">
            <h2>Contact</h2>
            <p class="muted" style="margin-top: 0.5rem; max-width: 60ch;">
              I’m interested in roles and collaborations across data science, applied AI, optimization, and technical consulting.
            </p>
            <div class="contact-box">
              <a class="button secondary" href="https://github.com/Ltabiaat" target="_blank" rel="noreferrer">GitHub</a>
              <a class="button secondary" href="https://www.linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
            </div>
          </div>
        </section>
      </div>
    </main>

    <footer>
      <div class="container">Built with Astro.</div>
    </footer>
  </body>
</html>
